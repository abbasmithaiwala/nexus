VITE_SPACETIMEDB_URL=wss://your_spacetimedb_url
VITE_SPACETIMEDB_MODULE=your_module_name
# Cloudflare TURN — server-side only, set in Vercel dashboard, NOT here
# Get these from Cloudflare Dashboard → Realtime → TURN → Create Key
# CLOUDFLARE_TURN_KEY_ID=your_key_id
# CLOUDFLARE_TURN_API_TOKEN=your_api_token

# Vercel KV (rate limiting) — auto-injected when you link a KV store in Vercel dashboard
# KV_REST_API_URL=your_kv_url
# KV_REST_API_TOKEN=your_kv_token